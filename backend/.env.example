DB_HOST=localhost
DB_PORT=3306
DB_NAME=Cafe-POS-DB
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ACCESS_SECONDS=3600
JWT_REFRESH_SECONDS=604800
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8080

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=""
SMTP_FROM=

# Port 587 uses STARTTLS. For implicit SSL, use port 465,
# set SMTP_SECURE=true, and set SMTP_STARTTLS=false.
SMTP_STARTTLS=true
SMTP_AUTH=true
SMTP_FROM_NAME=Cafe Etoile
